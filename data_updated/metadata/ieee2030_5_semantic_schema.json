{
  "schema_version": "1.0",
  "protocol_claim_level": "semantic_ieee2030_5_style",
  "description": "This schema defines a semantic IEEE 2030.5-style cyber event log. It models the IEEE 2030.5 DER management lifecycle (control, status, metering) at the semantic level. It does NOT represent actual serialized IEEE 2030.5 XML/EXI packets or real network packet captures. All protocol_claim_level values are 'semantic_ieee2030_5_style' unless actual protocol artifacts exist.",
  "lifecycle_stages": [
    "DER_CONTROL_CREATED",
    "DER_CONTROL_SENT",
    "DER_CONTROL_RECEIVED",
    "DER_CONTROL_ACCEPTED",
    "DER_CONTROL_REJECTED",
    "DER_CONTROL_APPLIED",
    "DER_CONTROL_RESPONSE",
    "DER_STATUS_REPORT",
    "DER_METER_READING",
    "SECURITY_AUTH_FAILURE",
    "SECURITY_REPLAY_DETECTED",
    "SECURITY_TIMEOUT",
    "SECURITY_BLOCKED_COMMAND",
    "SECURITY_INTEGRITY_MISMATCH"
  ],
  "resource_types": {
    "DERControl": {
      "function_set": "DER",
      "description": "DER active/reactive power or storage dispatch control",
      "control_modes": [
        "active_power_limit",
        "reactive_power_control",
        "storage_dispatch",
        "storage_reactive_support",
        "voltage_regulation"
      ]
    },
    "DERStatus": {
      "function_set": "DER",
      "description": "DER operational status report"
    },
    "MirrorMeterReading": {
      "function_set": "Metering",
      "description": "DER metering / PCC measurement data"
    },
    "EndDeviceControl": {
      "function_set": "DemandResponse",
      "description": "Demand response or device-level control"
    }
  },
  "cia_dimensions": [
    "CIA_C",
    "CIA_I",
    "CIA_A",
    "none"
  ],
  "protocol_claim_levels": {
    "semantic_ieee2030_5_style": "Semantic model of IEEE 2030.5 lifecycle. No actual serialized XML, EXI, or packet capture.",
    "serialized_ieee2030_5_xml": "Actual IEEE 2030.5 XML-serialized messages generated. Research-use artifacts only \u2014 not official compliance.",
    "serialized_ieee2030_5_exi": "Actual EXI-encoded IEEE 2030.5 messages generated. Research-use artifacts only.",
    "packet_capture": "Actual network packet captures of IEEE 2030.5 traffic. Requires real or emulated network infrastructure."
  },
